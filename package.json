{
  "name": "mcp-m365-bookmarklet",
  "version": "1.0.0",
  "description": "Standalone bookmarklet for MCP tool calling on M365 Copilot Chat",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "node esbuild.config.mjs --watch",
    "serve": "http-server dist -p 3007 --cors -c-1",
    "serve:https": "http-server dist -p 3443 --ssl --cert localhost+1.pem --key localhost+1-key.pem --cors -c-1",
    "serve:py": "python scripts/serve_https.py"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.4",
    "http-server": "^14.1.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
